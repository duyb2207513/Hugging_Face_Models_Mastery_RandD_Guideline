    {
      "cell_type": "markdown",
      "source": [
        "Loading model and data_collator"
      ],
      "metadata": {
        "id": "4Y1hbEwzqAcc"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from transformers import DataCollatorWithPadding\n",
        "data_collator=DataCollatorWithPadding(tokenizer=tokenizer)\n",
