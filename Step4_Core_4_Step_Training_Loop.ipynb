      "metadata": {
        "id": "kaUMo5SCEnbu"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "raw_train_dataset = raw_datasets[\"train\"]\n",
        "raw_train_dataset[0]\n",
        "raw_train_dataset.features"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "MWg9SROMZD2V",
