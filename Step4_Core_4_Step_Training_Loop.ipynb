      "cell_type": "code",
      "source": [
        "  from datasets import load_dataset\n",
        "  from trl import SFTConfig, SFTTrainer\n",
        "  from transformers import AutoModelForCausalLM, AutoTokenizer\n",
        "  import torch\n",
        "\n",
        "  # 1. Thiết lập thiết bị\n",
        "  device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "\n",
        "  # 2. Tải Dataset\n",
        "  # Dùng split=\"train\" vì dataset này thường chỉ có tập train\n",
        "  raw_dataset = load_dataset(\"HuggingFaceTB/smoltalk\", \"smol-summarize\", split=\"train\")\n",
        "\n",
        "  # 3. Khai báo System Prompt và Hàm biến đổi dữ liệu\n",
        "  system_message = 'Provide a concise, objective summary of the input text in up to three sentences, focusing on key actions and intentions without using second or third person pronouns.'\n",
        "\n",
        "  def convert_to_chatml(example):\n",
        "      # Cần kiểm tra xem dataset gốc dùng cột 'input'/'output' hay 'prompt'/'completion'\n",
        "      # Giả sử ở đây là cột 'prompt' và 'completion'\n",
        "      return {\n",
        "          \"messages\": [\n",
        "              {\"role\": \"system\", \"content\": system_message},      # Đưa system message vào đây\n",
        "              {\"role\": \"user\", \"content\": example.get(\"prompt\", example.get(\"input\", \"\"))},\n",
        "              {\"role\": \"assistant\", \"content\": example.get(\"completion\", example.get(\"output\", \"\"))},\n",
        "          ]\n",
        "      }\n",
        "\n",
        "  # ÁP DỤNG HÀM BIẾN ĐỔI (BƯỚC QUAN TRỌNG NHẤT BẠN BỊ THIẾU)\n",
        "  processed_dataset = raw_dataset.map(convert_to_chatml, remove_columns=raw_dataset.column_names)\n",
        "\n",
        "  # Tự động chia dataset: 90% để Train, 10% để Test/Eval\n",
        "  split_dataset = processed_dataset.train_test_split(test_size=0.1)\n",
        "\n",
        "  # 4. Cấu hình Model và Tokenizer\n",
        "  model_name = \"HuggingFaceTB/SmolLM2-135M\"\n",
        "  model = AutoModelForCausalLM.from_pretrained(model_name).to(device)\n",
        "  tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "\n",
        "  # Bỏ qua việc tự ép chat_template. Hãy để SFTTrainer tự dùng template xịn mặc định của SmolLM2\n",
        "  # (Nó sẽ tự hiểu cột \"messages\" mà chúng ta vừa map ở trên)\n",
        "\n",
        "  # 5. Cấu hình Trainer\n",
        "  training_args = SFTConfig(\n",
        "      output_dir=\"./sft_output\",\n",
        "      max_steps=1000,\n",
        "      per_device_train_batch_size=4,\n",
        "      learning_rate=5e-5,\n",
        "      logging_steps=10,\n",
        "      save_steps=100,\n",
        "      eval_strategy=\"steps\",\n",
        "      eval_steps=50,\n",
        "  )\n",
        "\n",
        "  # 6. Khởi tạo Trainer\n",
        "  trainer = SFTTrainer(\n",
        "      model=model,\n",
        "      args=training_args,\n",
        "      train_dataset=split_dataset[\"train\"], # Dùng tập đã chia\n",
        "      eval_dataset=split_dataset[\"test\"],   # Dùng tập đã chia\n",
        "      processing_class=tokenizer,\n",
        "  )\n",
        "\n",
        "  # 7. Kích hoạt huấn luyện\n",
        "  trainer.train()"
      ],
