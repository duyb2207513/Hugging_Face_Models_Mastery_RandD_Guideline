    {
      "cell_type": "markdown",
      "source": [
        "# Action: Implement high-level Trainer versus"
      ],
      "metadata": {
        "id": "2eW-EongIr4e"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "from transformers import TrainingArguments\n",
        "from transformers import Trainer\n",
        "\n",
        "# 1. Define superparameter\n",
        "training_args = TrainingArguments(\n",
        "    output_dir=\"./mrpc_bert_model\",         #result folder\n",
        "\n",
        "    # Config superparameter\n",
        "    learning_rate=2e-5,\n",
        "    num_train_epochs=3,\n",
        "    per_device_train_batch_size=16,         # Batch size when train\n",
        "    per_device_eval_batch_size=32,          # Batch size when test\n",
        "    weight_decay=0.01,                      # reduce overfitting\n",
        "\n",
        "    # config save and evaluate\n",
        "    eval_strategy=\"epoch\",\n",
        "    save_strategy=\"epoch\",\n",
        "    load_best_model_at_end=True,           #Save the best model\n",
        "\n",
        "    # Optimzied GPU\n",
        "    fp16=True,                              # Turn Mixed Precision (such as accelerate)\n",
        "\n",
        "    # Log kết quả hiển thị\n",
        "    logging_steps=50,                       # In loss ra màn hình mỗi 50 steps\n",
        "    report_to=\"none\"                        # Tắt report lên Wandb (nếu bạn không dùng)\n",
        ")\n",
        "# 2. Khởi tạo Trainer\n",
        "trainer= Trainer(\n",
        "    model,\n",
        "    training_args,\n",
        "    train_dataset=tokenized_datasets[\"train\"],\n",
        "    eval_dataset=tokenized_datasets[\"validation\"],\n",
        "    data_collator=data_collator,\n",
        "    processing_class=tokenizer\n",
        ")\n",
        "\n",
        "# 3. Kích hoạt huấn luyện\n",
        "trainer.train()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 372,
          "referenced_widgets": [
            "0a1ad30bee324c8284b784823e2b613e",
